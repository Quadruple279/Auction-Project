                           <children>
                              <TextField fx:id="bidAmountField" layoutX="16.0" layoutY="35.0" maxWidth="320.0" prefWidth="320.0" promptText="Nhập số tiền..." style="-fx-background-color: #1d1d1d; -fx-border-color: #555555; -fx-text-fill: #ffffff; -fx-border-radius: 6; -fx-background-radius: 6;">
                                 <font>
                                    <Font size="14.0" />
                                 </font>
                              </TextField>
                              <Button fx:id="placeBidButton" layoutX="345.0" layoutY="35.0" mnemonicParsing="false" onAction="#handlePlaceBid" style="-fx-background-color: #006aff; -fx-background-radius: 6;" text="Đặt giá " textFill="WHITE">
                                 <font>
                                    <Font size="14.0" />
                                 </font>
                              </Button>
                              <Label layoutX="16.0" layoutY="72.0" text="Giá tiền đặt phải cao hơn giá hiện tại" textFill="#888888" />
                              <Text fill="#888888" layoutX="16.0" layoutY="27.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Đặt giá " />
                           </children>
                        </AnchorPane>
                        <AnchorPane prefWidth="480.0" style="-fx-background-color: #2b2b2b; -fx-background-radius: 8;" VBox.vgrow="ALWAYS">
                           <children>
                              <Label layoutX="16.0" layoutY="12.0" text="LỊCH SỬ ĐẶT GIÁ" textFill="#888888" />
                              <ListView fx:id="bidHistoryList" layoutX="16.0" layoutY="35.0" prefWidth="448.0" style="-fx-background-color: #1d1d1d;                  -fx-border-color: transparent;                  -fx-background-radius: 6;                  -fx-control-inner-background: #1d1d1d;" AnchorPane.bottomAnchor="6.0" AnchorPane.topAnchor="30.0" />
                           </children>
                        </AnchorPane>
                     </children>
                  </VBox>
               </children>
               <VBox.margin>
                  <Insets left="10.0" right="10.0" />
               </VBox.margin>
            </HBox>
            <AnchorPane prefHeight="130.0" prefWidth="966.0" style="-fx-background-color: #2b2b2b;" VBox.vgrow="ALWAYS">
               <children>
                  <Label layoutX="16.0" layoutY="12.0" text="NOTIFICATIONS" textFill="#888888" />
                  <TextArea fx:id="console" editable="false" layoutX="16.0" layoutY="30.0" prefHeight="88.0" prefWidth="970.0" style="-fx-background-color: #1d1d1d;                  -fx-control-inner-background: #1d1d1d;                  -fx-text-fill: #666666;                  -fx-border-color: transparent;                  -fx-background-radius: 6;                  -fx-highlight-fill: #444444;" />
               </children>
               <padding>
                  <Insets left="6.0" right="6.0" />
               </padding>
            </AnchorPane>
         </children>
      </VBox>
   </children>
</AnchorPane>