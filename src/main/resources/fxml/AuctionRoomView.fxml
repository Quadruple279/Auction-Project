                                 <xAxis>
                                    <CategoryAxis fx:id="chartXAxis" tickLabelsVisible="false" tickMarkVisible="false"
                                                  style="-fx-tick-label-fill: #555555;" />
                                 </xAxis>
                                 <yAxis>
                                    <NumberAxis fx:id="chartYAxis" autoRanging="true"
                                                style="-fx-tick-label-fill: #888888;" />
                                 </yAxis>
                              </LineChart>
                           </children>
                        </AnchorPane>

                     </children>
                  </AnchorPane>
                  <VBox prefWidth="100.0" spacing="16.0" HBox.hgrow="ALWAYS">
